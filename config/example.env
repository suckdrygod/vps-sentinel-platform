# VPS Sentinel Platform example environment
# Copy to .env before deployment. install.sh does this automatically when .env is absent.

COMPOSE_PROJECT_NAME=vps-sentinel-platform

# External Docker network. The installer only creates it when --create-network is provided.
VPS_SENTINEL_NETWORK=vps-sentinel-external

# Pinned Komari backend image. Do not use latest for production.
KOMARI_IMAGE=ghcr.io/suckdrygod/komari:1.2.6-tg.32
KOMARI_HOST=127.0.0.1
KOMARI_PORT=25874
KOMARI_DATA_DIR=./data/komari

# Source checkout directory for pinned references.
SOURCE_DIR=./sources

# Pinned repositories.
KOMARI_REPO=https://github.com/suckdrygod/komari.git
KOMARI_REF=release/1.2.6-tg.32
KOMARI_COMMIT=689968acc219f227338e473a886f5590cee6026d

TCPPING_REPO=https://github.com/suckdrygod/tcpping.git
TCPPING_REF=v1.2.13-safe.13
TCPPING_COMMIT=aa379696c97d9ad09eff82b0065a89cfa00ae3a0

KOMARI_WEB_REPO=https://github.com/suckdrygod/komari-web.git
KOMARI_WEB_REF=radix
KOMARI_WEB_COMMIT=96d3c74eacf476aa915d6448fb95ee9663942b98

# Optional frontend preview profile. It is disabled unless explicitly started.
KOMARI_WEB_HOST=127.0.0.1
KOMARI_WEB_PORT=25875

# Theme path reservation only. This platform does not auto-load it.
THEME_EMERALD_PRO_CSS=/theme/emerald-pro/index.css

# Safety defaults. These values are documentation/installer hints only.
ENABLE_AGENT=false
SSH_AUTH_GUARD=false
SSH_AUTH_AUTO_BAN=false
